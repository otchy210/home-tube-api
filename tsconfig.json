{
    "compilerOptions": {
        "target": "es2019",
        "module": "commonjs",
        "moduleResolution": "node",
        "strict": true,
        "skipLibCheck": true,
        "declaration": true,
        "pretty": true,
        "newLine": "lf",
        "outDir": "dist",
        "types": ["node", "jest"]
    },
    "include": ["src/**/*.ts"],
    "exclude": ["node_modules"]
}
